<?xml version="1.0" encoding="utf-8"?>
<!--
  PlayerView с surface_type="texture_view".

  По умолчанию PlayerView рисует видео в SurfaceView — отдельный слой композитора вне
  иерархии View. Внутри Dialog позиционирование/обрезка этого слоя по рамке
  AspectRatioFrameLayout ведёт себя по-разному на разных версиях Android: на 12+/14 видео
  растягивается на всё окно, на 11 — нормально. TextureView рисуется в холсте View внутри
  иерархии и честно соблюдает пропорции на всех версиях. surface_type задаётся только в XML.
-->
<androidx.media3.ui.PlayerView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black"
    app:surface_type="texture_view"
    app:resize_mode="fit"
    app:use_controller="true" />
